NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

PAYMENTS_ENABLED=true
PAYMENT_PROVIDER=mercado_pago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-seu-access-token
MERCADOPAGO_WEBHOOK_URL=https://SEU-REF.supabase.co/functions/v1/mercadopago-webhook
APP_BASE_URL=http://localhost:3000

# Melhor Envio — OAuth (recomendado)
MELHOR_ENVIO_CLIENT_ID=
MELHOR_ENVIO_CLIENT_SECRET=
# Opcional: força redirect (default = APP_BASE_URL/api/admin/melhor-envio/callback)
# MELHOR_ENVIO_REDIRECT_URI=https://sua-loja.vercel.app/api/admin/melhor-envio/callback
# MELHOR_ENVIO_SANDBOX=true
# MELHOR_ENVIO_USER_AGENT=LM Moda (seu@email.com)

# Fallback legado (token manual que expira rápido — opcional se OAuth estiver ok)
MELHOR_ENVIO_TOKEN=
